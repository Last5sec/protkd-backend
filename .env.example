# PTF India Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 4000)
PORT=4000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# JWT secret — change this in production!
JWT_SECRET=ptfindia_change_this_to_a_long_random_secret

# Admin default password
ADMIN_PASSWORD=admin123

# ── Email Notifications ───────────────────────────────────────
# Gmail is easiest. Steps:
# 1. Go to your Google Account → Security → 2-Step Verification (enable it)
# 2. Then go to Security → App Passwords
# 3. Create an app password for "Mail" → copy the 16-character password
# 4. Paste it as EMAIL_PASS below (NOT your normal Gmail password)

EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Where to send notifications (defaults to EMAIL_USER if not set)
NOTIFY_EMAIL=your-gmail@gmail.com

# ── Razorpay Payment Gateway ──────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# KEY_ID is public (can be in frontend)
# KEY_SECRET is private (backend only!)
RAZORPAY_KEY_ID=rzp_test_Sp8ajKiVVb3yCM
RAZORPAY_KEY_SECRET=1hDfiOxYFgvH00YwPPuMX6WE
